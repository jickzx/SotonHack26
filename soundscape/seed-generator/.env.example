# Rename this file to .env and fill in your credentials.
# Get Spotify credentials at: https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=YOUR_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Most dev-mode Spotify apps can no longer use /audio-features.
# Leave this as off to skip the blocked endpoint and use preview analysis first.
# Valid values: off, auto, force
SPOTIFY_AUDIO_FEATURES_MODE=off
